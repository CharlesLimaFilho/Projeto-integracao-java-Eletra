<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox id="VBox" xmlns="http://javafx.com/javafx/8.0.51" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controller.Controller">
    <children>
        <HBox style="-fx-padding: 0 5">
            <Text text="Autor: Charles Lima de Brito Filho">
                <font>
                    <Font size="12.0" />
                </font></Text>
        </HBox>
        <Separator style="-fx-padding: 5 5;" />
        <Accordion style="-fx-padding: 0 5 5 5">
            <panes>
                <TitledPane animated="false" style="-fx-padding: 0 0 5 0" text="Linhas">
                    <content>
                        <HBox prefHeight="70.0" style="-fx-alignment: center-left">
                            <children>
                                <HBox style="-fx-padding: 0 5; -fx-alignment: center">
                                    <Label style="-fx-padding: 0 20 0 0">Selecione uma linha:</Label>
                                    <ComboBox fx:id="cbLines" prefHeight="10.0" prefWidth="183.0">
                                    </ComboBox>
                                </HBox>
                            </children>
                        </HBox>
                    </content>
                </TitledPane>
                <TitledPane fx:id="tpModels" animated="false" text="Modelos" disable="true">
                    <content>
                        <HBox>
                            <children>
                                <HBox>
                                    <Label style="-fx-padding: 0 20 0 0">Lista de Modelos</Label>
                                    <ScrollPane prefHeight="200.0">
                                        <content>
                                            <TreeView fx:id="tvModels">
                                            </TreeView>
                                        </content>
                                    </ScrollPane>
                                </HBox>
                            </children>
                        </HBox>
                    </content>
                </TitledPane>
            </panes>
        </Accordion>
    </children>
</VBox>